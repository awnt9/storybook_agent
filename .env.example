API_HOST=0.0.0.0
API_PORT=8000

DATABASE_URL=postgresql://postgres:postgres@db:5432/storybook_agent

JWT_SECRET_KEY=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

REFRESH_TOKEN_COOKIE_NAME=
COOKIE_SECURE=
COOKIE_SAMESITE=

# Generate with: docker compose run --rm --no-deps backend python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=

DEBUG=false

BG_MODEL=openai:gpt-4o-mini
BG_IMAGE_MODEL=dall-e-3
BG_IMAGE_SIZE=1792x1024

# Docker Compose
FRONTEND_PORT=5173
VITE_API_PROXY_TARGET=http://backend:8000

POSTGRES_IMAGE=postgres:16
POSTGRES_DB=storybook_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

MINIO_IMAGE=minio/minio:latest
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=storybook
MINIO_SECURE=false
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
